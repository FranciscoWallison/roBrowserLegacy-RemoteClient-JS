PORT=3338
CLIENT_PUBLIC_URL=http://127.0.0.1:8000
NODE_ENV=development

# Cache settings
CACHE_MAX_FILES=5000
CACHE_MAX_MEMORY_MB=1024

# Warm-up: pre-loads frequently used assets into cache on startup
# CACHE_WARM_UP=true  - Enable cache warm-up
# CACHE_WARM_UP_LIMIT=500  - Max files to pre-load
CACHE_WARM_UP=true
CACHE_WARM_UP_LIMIT=500

# Unified server settings
# ENABLE_WSPROXY=true  - Embeds WebSocket proxy (replaces standalone wsproxy)
# ENABLE_STATIC_SERVE=true - Serves roBrowserLegacy static files (replaces live-server)
ENABLE_WSPROXY=true
ENABLE_STATIC_SERVE=true
ROBROWSER_PATH=../roBrowserLegacy

# WS proxy target allowlist (only used when ENABLE_WSPROXY=true)
# Comma-separated "host:port" pairs the proxy is permitted to forward to.
# Defaults to localhost only (127.0.0.1:6900, 6121, 5121) when not set.
# Override for non-host-network deployments where rAthena is on a different host:
#   WS_ALLOWED_TARGETS=10.0.0.5:6900,10.0.0.5:6121,10.0.0.5:5121
# Docker Desktop (macOS/Windows):
#   WS_ALLOWED_TARGETS=host.docker.internal:6900,host.docker.internal:6121,host.docker.internal:5121
#WS_ALLOWED_TARGETS=
